<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>NagarDrishti — Live Dashboard</title>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.css"/>
<style>
:root{
  --w:#fff;--g50:#F8F9FB;--g100:#EFF1F5;--g200:#DDE1EA;--g300:#B8C0D0;--g400:#8892A4;
  --n9:#0F1C3F;--n8:#1B2A5C;--n6:#2D3E8E;
  --b6:#0052CC;--b5:#1664D6;--b4:#3D80EF;--b1:#E8F0FE;--b0:#F0F5FF;
  --gh:linear-gradient(135deg,#0F1C3F 0%,#1B2A5C 40%,#2D3E8E 100%);
  --red:#DC2626;--rb:#FEF2F2;--amb:#D97706;--ab:#FFFBEB;
  --grn:#059669;--gb:#ECFDF5;--tel:#0891B2;--tb:#ECFEFF;--vio:#7C3AED;--vb:#F5F3FF;
  --t9:#0F1C3F;--t7:#374151;--t5:#6B7280;--t3:#9CA3AF;
  --s1:0 1px 3px rgba(15,28,63,.08);--s2:0 4px 16px rgba(15,28,63,.10);
  --s3:0 10px 40px rgba(15,28,63,.12);--s4:0 24px 64px rgba(15,28,63,.15);
  --ff:'Plus Jakarta Sans',sans-serif;--fm:'IBM Plex Mono',monospace;
  --r1:4px;--r2:8px;--r3:12px;--r4:16px;
}
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
html,body{height:100%;overflow:hidden;background:var(--g50);color:var(--t9);font-family:var(--ff);-webkit-font-smoothing:antialiased}
::-webkit-scrollbar{width:4px}::-webkit-scrollbar-thumb{background:var(--g300);border-radius:4px}
#loader{position:fixed;inset:0;background:var(--w);z-index:9999;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:16px;transition:opacity .5s}
#loader.gone{opacity:0;pointer-events:none}
.ld-ring{width:40px;height:40px;border:3px solid var(--g200);border-top-color:var(--b6);border-radius:50%;animation:spin 1s linear infinite}
@keyframes spin{to{transform:rotate(360deg)}}
.ld-txt{font-family:var(--fm);font-size:11px;color:var(--t3);letter-spacing:.12em;text-transform:uppercase}
.shell{display:grid;grid-template-rows:58px 1fr;height:100vh;overflow:hidden}
.main{display:grid;grid-template-columns:258px 1fr 272px;height:100%;overflow:hidden}
.topbar{background:rgba(255,255,255,.96);backdrop-filter:blur(16px);border-bottom:1px solid var(--g100);box-shadow:var(--s1);display:flex;align-items:center;gap:10px;padding:0 16px;flex-shrink:0;z-index:400}
.tb-logo{display:flex;align-items:center;gap:9px;cursor:pointer;flex-shrink:0;text-decoration:none}
.tb-icon{width:32px;height:32px;border-radius:var(--r2);background:var(--gh);display:flex;align-items:center;justify-content:center;font-size:15px;box-shadow:0 4px 12px rgba(15,28,63,.25)}
.tb-name{font-size:15px;font-weight:800;color:var(--n9);letter-spacing:-.01em}
.tb-sub{font-family:var(--fm);font-size:8px;color:var(--t3);letter-spacing:.08em;text-transform:uppercase;margin-top:1px}
.tb-sep{width:1px;height:22px;background:var(--g200);flex-shrink:0}
.breadcrumb{display:flex;align-items:center;gap:4px;flex:1;min-width:0;overflow:hidden}
.bc-item{font-family:var(--fm);font-size:10px;color:var(--t5);cursor:pointer;transition:color .12s;white-space:nowrap;letter-spacing:.03em}
.bc-item:hover{color:var(--b6)}.bc-item.active{color:var(--n9);font-weight:600}
.bc-sep{color:var(--t3);font-size:10px;flex-shrink:0}
.bc-up{display:none;align-items:center;gap:5px;background:var(--g50);border:1px solid var(--g200);border-radius:var(--r2);padding:4px 9px;cursor:pointer;transition:all .12s;font-family:var(--fm);font-size:10px;color:var(--t5);white-space:nowrap;flex-shrink:0}
.bc-up:hover{border-color:var(--b6);color:var(--b6)}.bc-up.show{display:flex}
.kpi-row{display:flex;align-items:center;gap:1px;flex-shrink:0}
.kpi{padding:4px 10px;border-left:1px solid var(--g100)}
.kpi-v{font-family:var(--fm);font-size:13px;font-weight:600;line-height:1}
.kpi-l{font-family:var(--fm);font-size:7.5px;color:var(--t3);letter-spacing:.07em;text-transform:uppercase;margin-top:2px}
.freshness{display:flex;align-items:center;gap:5px;background:var(--g50);border:1px solid var(--g200);border-radius:20px;padding:4px 10px;flex-shrink:0;cursor:pointer;transition:all .13s}
.freshness:hover{border-color:var(--b6)}
.fresh-dot{width:5px;height:5px;border-radius:50%;background:var(--grn);flex-shrink:0;transition:background .3s}
.fresh-dot.stale{background:var(--amb);animation:bl2 1s ease-in-out infinite}
.fresh-dot.spin{background:var(--b6);animation:spin .8s linear infinite}
.fresh-txt{font-family:var(--fm);font-size:9px;color:var(--t5);letter-spacing:.04em;white-space:nowrap}
@keyframes bl2{0%,100%{opacity:1}50%{opacity:.3}}
.em-banner{display:none;position:fixed;top:58px;left:0;right:0;z-index:600;background:var(--red);color:#fff;padding:7px 20px;font-family:var(--fm);font-size:11px;letter-spacing:.06em;text-align:center;animation:emP 2s ease-in-out infinite}
.em-banner.show{display:flex;align-items:center;justify-content:center;gap:10px}
@keyframes emP{0%,100%{opacity:1}50%{opacity:.85}}
.em-close{background:rgba(255,255,255,.2);border:none;border-radius:var(--r1);color:#fff;font-size:12px;padding:2px 8px;cursor:pointer;flex-shrink:0}
.live-pill{display:flex;align-items:center;gap:5px;background:#DCFCE7;border:1px solid #BBF7D0;border-radius:20px;padding:4px 9px;flex-shrink:0}
.live-dot{width:5px;height:5px;border-radius:50%;background:var(--grn);animation:bl2 1.6s ease-in-out infinite}
.live-txt{font-family:var(--fm);font-size:9px;color:#166534;letter-spacing:.08em}
.tb-clock{font-family:var(--fm);font-size:11px;color:var(--t3);letter-spacing:.06em;flex-shrink:0}
.btn-primary{background:var(--b6);border:none;border-radius:var(--r2);font-size:12px;font-weight:700;color:#fff;padding:7px 13px;cursor:pointer;transition:all .17s;font-family:var(--ff);box-shadow:0 2px 8px rgba(0,82,204,.28);white-space:nowrap}
.btn-primary:hover{background:var(--b5);transform:translateY(-1px)}
.btn-ghost{background:none;border:1.5px solid var(--g200);border-radius:var(--r2);font-size:11.5px;font-weight:600;color:var(--t7);padding:6px 11px;cursor:pointer;transition:all .13s;font-family:var(--ff);white-space:nowrap}
.btn-ghost:hover{border-color:var(--b6);color:var(--b6)}
.sidebar-l{background:var(--w);border-right:1px solid var(--g200);overflow-y:auto;padding:13px;display:flex;flex-direction:column;gap:13px;box-shadow:var(--s1)}
.pan-title{font-family:var(--fm);font-size:9px;color:var(--t3);letter-spacing:.14em;text-transform:uppercase;margin-bottom:8px;display:flex;align-items:center;gap:6px}
.pan-title::after{content:'';flex:1;height:1px;background:var(--g100)}
.pan-box{background:var(--w);border:1px solid var(--g200);border-radius:var(--r3);padding:11px;box-shadow:var(--s1)}
.hb-card{background:var(--w);border:1px solid var(--g200);border-radius:var(--r3);padding:13px;box-shadow:var(--s1);position:relative;overflow:hidden}
.hb-city{font-size:12px;font-weight:700;color:var(--n9);margin-bottom:3px}
.hb-score-row{display:flex;align-items:baseline;gap:6px;margin-bottom:8px}
.hb-score{font-size:32px;font-weight:800;line-height:1;letter-spacing:-.03em;transition:color .4s}
.hb-sub{font-family:var(--fm);font-size:9px;color:var(--t3);letter-spacing:.06em}
.hb-bar-wrap{height:6px;background:var(--g100);border-radius:3px;overflow:hidden;margin-bottom:7px}
.hb-bar{height:100%;border-radius:3px;transition:width .8s cubic-bezier(.22,1,.36,1),background .4s}
.hb-grid{display:grid;grid-template-columns:1fr 1fr;gap:5px}
.hb-cell{background:var(--g50);border:1px solid var(--g100);border-radius:var(--r2);padding:6px 8px}
.hb-v{font-family:var(--fm);font-size:12px;font-weight:600;line-height:1}
.hb-l{font-family:var(--fm);font-size:8px;color:var(--t3);letter-spacing:.07em;text-transform:uppercase;margin-top:2px}
.hb-pulse{position:absolute;top:10px;right:10px;width:8px;height:8px;border-radius:50%;background:var(--grn)}
.hb-pulse::after{content:'';position:absolute;inset:-3px;border-radius:50%;border:2px solid var(--grn);animation:hbR 1.8s ease-out infinite}
@keyframes hbR{0%{transform:scale(1);opacity:.8}100%{transform:scale(2.2);opacity:0}}
.zoom-levels{display:flex;flex-direction:column;gap:3px;margin-top:8px}
.zl{display:flex;align-items:center;gap:8px;padding:7px 10px;border-radius:var(--r2);cursor:pointer;border:1px solid transparent;transition:all .13s;font-family:var(--fm);font-size:10px;color:var(--t5);letter-spacing:.03em}
.zl:hover{background:var(--g50);border-color:var(--g200);color:var(--t7)}
.zl.active{background:var(--b0);border-color:#C7D9FF;color:var(--b6);font-weight:600}
.zl-ico{font-size:12px;flex-shrink:0;width:20px;text-align:center}
.zl-num{font-family:var(--fm);font-size:8px;color:var(--t3);margin-left:auto}
.ltab{display:flex;align-items:center;gap:8px;padding:7px 10px;border-radius:var(--r2);cursor:pointer;border:1px solid var(--g200);background:var(--w);margin-bottom:4px;font-family:var(--ff);font-size:12px;color:var(--t5);transition:all .13s}
.ltab:last-child{margin-bottom:0}.ltab:hover{border-color:var(--b4);color:var(--b6)}
.ltab.active{background:var(--b6);border-color:var(--b6);color:#fff}
.ltab.active .ltab-count{color:rgba(255,255,255,.7)}
.ltab.em-active{border-color:var(--red) !important;background:var(--rb) !important;color:var(--red) !important;animation:emT .8s ease-in-out infinite}
@keyframes emT{0%,100%{opacity:1}50%{opacity:.7}}
.ltab-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0}
.ltab-count{margin-left:auto;font-family:var(--fm);font-size:9.5px;color:var(--t3)}
.leg-row{display:flex;align-items:center;gap:8px;margin-bottom:6px}
.leg-row:last-child{margin-bottom:0}
.leg-dot{width:10px;height:10px;border-radius:50%;flex-shrink:0;border:1.5px solid}
.leg-lbl{font-size:11.5px;color:var(--t7);flex:1}.leg-note{font-family:var(--fm);font-size:9px;color:var(--t3)}
.meter{margin-bottom:7px}.meter:last-child{margin-bottom:0}
.meter-hd{display:flex;justify-content:space-between;margin-bottom:4px}
.meter-lbl{font-size:11.5px;color:var(--t7)}.meter-val{font-family:var(--fm);font-size:10.5px;font-weight:600}
.meter-track{height:4px;background:var(--g100);border-radius:2px;overflow:hidden}
.meter-fill{height:100%;border-radius:2px;transition:width .6s}
.rrow{display:flex;align-items:center;gap:7px;padding:6px 8px;border-radius:var(--r2);cursor:pointer;transition:all .12s;border:1px solid transparent}
.rrow:hover{background:var(--g50);border-color:var(--g200)}
.rn{font-family:var(--fm);font-size:10px;color:var(--t3);width:16px;text-align:center;flex-shrink:0}
.rn.g{color:var(--amb)}.rn.s{color:var(--t5)}.rn.b{color:var(--b6)}
.rc{font-size:12px;flex:1;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;color:var(--t7)}
.rbw{flex:1;height:3px;background:var(--g100);border-radius:2px;overflow:hidden}
.rbf{height:100%;border-radius:2px}.rs{font-family:var(--fm);font-size:10px;width:22px;text-align:right;font-weight:600}
.search-row{display:flex;gap:6px}
.search-inp{flex:1;background:var(--w);border:1.5px solid var(--g200);border-radius:var(--r2);font-family:var(--ff);font-size:12px;color:var(--t7);padding:7px 11px;outline:none;transition:border-color .12s}
.search-inp:focus{border-color:var(--b6)}.search-inp::placeholder{color:var(--t3)}
.search-go{background:var(--b6);border:none;border-radius:var(--r2);color:#fff;font-family:var(--ff);font-size:11px;font-weight:700;padding:7px 12px;cursor:pointer;transition:all .12s}
.search-go:hover{background:var(--b5)}
#map{width:100%;height:100%;background:var(--g50);z-index:1}
.map-wrap{position:relative;height:100%;background:var(--g50)}
.drill-tip{position:absolute;bottom:20px;left:50%;transform:translateX(-50%);background:rgba(15,28,63,.82);border:1px solid rgba(255,255,255,.12);border-radius:20px;padding:7px 16px;font-family:var(--fm);font-size:10px;color:rgba(255,255,255,.8);letter-spacing:.07em;z-index:500;pointer-events:none;white-space:nowrap;backdrop-filter:blur(8px);transition:opacity .3s}
.drill-tip.hide{opacity:0}
.refresh-ring{position:absolute;top:14px;right:14px;width:32px;height:32px;z-index:500;display:none}
.refresh-ring.show{display:block}
.refresh-ring svg{width:32px;height:32px;animation:spin .8s linear infinite}
.spotlight{position:absolute;top:14px;left:14px;width:278px;background:rgba(255,255,255,.97);backdrop-filter:blur(12px);border:1px solid var(--g200);border-radius:var(--r4);box-shadow:var(--s4);z-index:600;transform:translateX(-110%);transition:transform .3s cubic-bezier(.22,1,.36,1);max-height:calc(100vh - 100px);overflow-y:auto}
.spotlight.open{transform:translateX(0)}
.sp-hd{padding:14px 16px 10px;border-bottom:1px solid var(--g100);display:flex;align-items:flex-start;justify-content:space-between}
.sp-type{font-family:var(--fm);font-size:8.5px;color:var(--t3);letter-spacing:.12em;text-transform:uppercase;margin-bottom:4px}
.sp-name{font-size:15px;font-weight:800;color:var(--n9);letter-spacing:-.01em;line-height:1.2}
.sp-close{background:var(--g100);border:1px solid var(--g200);border-radius:var(--r1);width:24px;height:24px;display:flex;align-items:center;justify-content:center;cursor:pointer;color:var(--t5);font-size:12px;flex-shrink:0;transition:all .12s}
.sp-close:hover{background:var(--rb);color:var(--red);border-color:#FCA5A5}
.sp-body{padding:14px 16px}
.sp-stats{display:grid;grid-template-columns:1fr 1fr 1fr;gap:7px;margin-bottom:13px}
.sp-stat{background:var(--g50);border:1px solid var(--g200);border-radius:var(--r2);padding:8px 10px;text-align:center}
.sp-stat-v{font-size:17px;font-weight:800;line-height:1;letter-spacing:-.02em}
.sp-stat-l{font-family:var(--fm);font-size:8px;color:var(--t3);letter-spacing:.07em;text-transform:uppercase;margin-top:3px}
.sp-sec{font-family:var(--fm);font-size:8.5px;color:var(--t3);letter-spacing:.10em;text-transform:uppercase;margin-bottom:8px;display:flex;align-items:center;gap:6px}
.sp-sec::after{content:'';flex:1;height:1px;background:var(--g100)}
.sp-arow{display:flex;align-items:center;gap:8px;padding:7px 9px;background:var(--g50);border:1px solid var(--g200);border-radius:var(--r2);margin-bottom:5px;cursor:pointer;transition:all .12s}
.sp-arow:hover{background:var(--b0);border-color:#C7D9FF}
.sp-aico{font-size:15px;flex-shrink:0;width:24px;text-align:center}
.sp-albl{font-size:12px;color:var(--t7);flex:1}
.sp-ast{font-family:var(--fm);font-size:9px;padding:2px 6px;border-radius:var(--r1);border:1px solid}
.sp-actions{display:flex;gap:7px;margin-top:12px}
.sp-btn{flex:1;border:1.5px solid var(--g200);border-radius:var(--r2);background:var(--g50);color:var(--t7);font-family:var(--ff);font-size:11px;font-weight:600;padding:7px;cursor:pointer;transition:all .12s;text-align:center}
.sp-btn:hover{border-color:var(--b6);color:var(--b6);background:var(--b0)}
.sp-btn.d{border-color:var(--red);color:var(--red);background:var(--rb)}
.sp-btn.d:hover{background:var(--red);color:#fff}
.leaflet-popup-content-wrapper{background:var(--w) !important;border:1px solid var(--g200) !important;border-radius:var(--r4) !important;box-shadow:var(--s4) !important;padding:0 !important}
.leaflet-popup-content{margin:0 !important;min-width:200px}
.leaflet-popup-tip{background:var(--w) !important}
.leaflet-popup-close-button{color:var(--t3) !important;font-size:16px !important;right:10px !important;top:8px !important}
.pop{padding:14px}
.pop-tag{font-family:var(--fm);font-size:8px;color:var(--t3);letter-spacing:.12em;text-transform:uppercase;margin-bottom:4px}
.pop-city{font-size:14px;font-weight:800;color:var(--n9);margin-bottom:5px}
.pop-issue{font-size:11.5px;color:var(--t5);line-height:1.6;margin-bottom:10px}
.pop-badges{display:flex;gap:5px;flex-wrap:wrap;margin-bottom:10px}
.pop-badge{font-family:var(--fm);font-size:8.5px;padding:2px 7px;border-radius:var(--r1);font-weight:500;border:1px solid}
.pop-actions{display:flex;gap:6px}
.pop-btn{flex:1;border:1.5px solid var(--g200);border-radius:var(--r2);background:var(--g50);color:var(--t7);font-family:var(--ff);font-size:11px;font-weight:600;padding:6px;cursor:pointer;transition:all .12s;text-align:center}
.pop-btn:hover{border-color:var(--b6);color:var(--b6);background:var(--b0)}
.pop-btn.d{border-color:var(--red);color:var(--red);background:var(--rb)}
.pop-btn.d:hover{background:var(--red);color:#fff}
.pop-drill{width:100%;background:var(--b6);border:none;border-radius:var(--r2);color:#fff;font-family:var(--ff);font-size:11px;font-weight:700;padding:7px;cursor:pointer;transition:all .12s;margin-top:7px}
.pop-drill:hover{background:var(--b5)}
.sidebar-r{background:var(--w);border-left:1px solid var(--g200);overflow-y:auto;padding:13px;display:flex;flex-direction:column;gap:13px;box-shadow:var(--s1)}
.ac{display:flex;align-items:flex-start;gap:7px;padding:8px 9px;border-radius:var(--r3);border:1px solid;border-left:3px solid;margin-bottom:5px;cursor:pointer;transition:box-shadow .12s}
.ac:last-child{margin-bottom:0}.ac:hover{box-shadow:var(--s2)}
.ac.crit{background:var(--rb);border-color:#FCA5A5;border-left-color:var(--red)}
.ac.warn{background:var(--ab);border-color:#FCD34D;border-left-color:var(--amb)}
.ac.info{background:var(--tb);border-color:#67E8F9;border-left-color:var(--tel)}
.ac.good{background:var(--gb);border-color:#6EE7B7;border-left-color:var(--grn)}
.ac-ico{font-size:12px;flex-shrink:0;margin-top:1px}
.ac-body{flex:1;min-width:0}
.ac-title{font-size:11px;font-weight:600;color:var(--n9);line-height:1.35;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.ac-sub{font-family:var(--fm);font-size:9px;color:var(--t3);margin-top:2px}
.ac-time{font-family:var(--fm);font-size:9px;color:var(--t3);flex-shrink:0;margin-top:1px}
.trend-row{display:flex;align-items:center;gap:7px;margin-bottom:7px}
.trend-row:last-child{margin-bottom:0}
.trend-lbl{font-size:11px;color:var(--t7);width:80px;flex-shrink:0}
.trend-track{flex:1;height:4px;background:var(--g100);border-radius:2px;overflow:hidden}
.trend-fill{height:100%;border-radius:2px;transition:width .8s}
.trend-delta{font-family:var(--fm);font-size:9px;width:30px;text-align:right;flex-shrink:0}
.fe{display:flex;gap:7px;padding:8px 0;border-bottom:1px solid var(--g100)}
.fe:last-child{border-bottom:none;padding-bottom:0}
.fa{width:28px;height:28px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:13px;flex-shrink:0}
.fb{flex:1;min-width:0}
.fw{display:flex;align-items:center;justify-content:space-between;margin-bottom:2px}
.fw-name{font-size:11px;font-weight:600;color:var(--n9)}.fw-time{font-family:var(--fm);font-size:8.5px;color:var(--t3)}
.fd{font-size:10.5px;color:var(--t5);line-height:1.55;margin-bottom:3px}.ft{font-family:var(--fm);font-size:9px;color:var(--t3)}
.toast{position:fixed;bottom:22px;right:18px;background:var(--w);border:1px solid var(--g200);border-left:3px solid var(--b6);border-radius:var(--r3);padding:11px 16px;font-size:13px;color:var(--t7);box-shadow:var(--s4);z-index:9999;transform:translateY(80px);opacity:0;transition:all .32s cubic-bezier(.22,1,.36,1);max-width:320px;pointer-events:none}
.toast.show{transform:translateY(0);opacity:1}
.overlay{position:fixed;inset:0;background:rgba(15,28,63,.55);backdrop-filter:blur(8px);z-index:7000;display:flex;align-items:center;justify-content:center;opacity:0;pointer-events:none;transition:opacity .2s}
